{
  "name": "@ludylops/youtube-video-analyzer-mcp",
  "mcpName": "io.github.ludmila-omlopes/youtube-video-analyzer",
  "version": "0.2.0",
  "description": "MCP stdio server for analyzing YouTube videos with Google Gemini",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ludmila-omlopes/youtube-video-analyzer-mcp.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "youtube-video-analyzer-mcp": "bin/youtube-video-analyzer-mcp.js"
  },
  "files": [
    "bin",
    "dist/index.js",
    "dist/server.js",
    "dist/lib",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node bin/youtube-video-analyzer-mcp.js",
    "test": "npm run build && node dist/test/index.js"
  },
  "keywords": [
    "mcp",
    "gemini",
    "youtube",
    "video-analysis"
  ],
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.6.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
