{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ludmila-omlopes/youtube-video-analyzer",
  "description": "MCP stdio server for analyzing YouTube videos with Google Gemini",
  "repository": {
    "url": "https://github.com/ludmila-omlopes/youtube-video-analyzer-mcp-server",
    "source": "github"
  },
  "version": "0.3.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@ludylops/youtube-video-analyzer-mcp",
      "version": "0.3.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Google Gemini API key.",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "GEMINI_API_KEY"
        },
        {
          "description": "YouTube Data API v3 key required for get_youtube_video_metadata.",
          "isRequired": false,
          "format": "string",
          "isSecret": true,
          "name": "YOUTUBE_API_KEY"
        },
        {
          "description": "Optional Gemini model override.",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "GEMINI_MODEL"
        },
        {
          "description": "Optional path to a yt-dlp executable.",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "YT_DLP_PATH"
        }
      ]
    }
  ]
}
