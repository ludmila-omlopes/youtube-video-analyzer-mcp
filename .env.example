GEMINI_API_KEY=your_gemini_api_key_here
YOUTUBE_API_KEY=your_youtube_api_key_here
GEMINI_MODEL=gemini-2.5-pro
YT_DLP_PATH=yt-dlp

# Optional remote MCP OAuth 2.1 resource-server settings
# OAUTH_ENABLED=false
# OAUTH_ISSUER=https://issuer.example.com/
# OAUTH_AUDIENCE=https://your-service.onrender.com/api/mcp
# OAUTH_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
# OAUTH_REQUIRED_SCOPE=mcp:access
#
# Optional remote session persistence
# SESSION_STORE_DRIVER=redis
# REDIS_URL=redis://localhost:6379
#
# Initial credit balance for new remote accounts (HTTP + OAuth)
# REMOTE_ACCOUNT_INITIAL_CREDITS=100
